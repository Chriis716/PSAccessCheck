Get-CimInstance Win32_UserProfile |
    Select-Object LocalPath, SID, Loaded, Special

$Profile = Get-CimInstance Win32_UserProfile |
    Where-Object { $_.LocalPath -eq 'C:\Users\username' -and -not $_.Loaded }

$Profile | Remove-CimInstance


