Get-CimInstance Win32_UserProfile |
    Select-Object LocalPath, SID, Loaded, Special

$Profile = Get-CimInstance Win32_UserProfile |
    Where-Object { $_.LocalPath -eq 'C:\Users\username' -and -not $_.Loaded }

$Profile | Remove-CimInstance


++++++++++++++

Get-CimInstance Win32_UserProfile |
    Where-Object { -not $_.Special } |
    Select-Object LocalPath, Loaded, SID, LastUseTime |
    Sort-Object LocalPath


Get-ChildItem 'C:\Users' -Directory |
    Where-Object { $_.Name -match 'temp|\.domain|^username$' } |
    Select-Object FullName, LastWriteTime


\Get-WinEvent -LogName Application -MaxEvents 200 |
    Where-Object { $_.ProviderName -match 'User Profile Service' } |
    Select-Object TimeCreated, Id, LevelDisplayName, Message



